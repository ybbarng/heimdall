# Discord Webhook URL (법원 워처와 같은 웹훅을 써도 된다)
# 서버 설정 > 연동 > 웹후크 > 새 웹후크 > URL 복사
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# 계층 폴링 간격 (초, 데몬 모드에서만). 알림 지점은 자주, 전국(지도용)은 드물게
POLL_NOTIFY_SECONDS=60
POLL_ALL_SECONDS=300

# 연속 조회 실패가 이 횟수에 닿을 때만 오류 알림을 1회 보낸다 (기본: 5)
FAIL_ALERT_THRESHOLD=5

# 롯데마트 상품 검색어 (기본: 스위치2)
SEARCH_WORD=스위치2

# 감시할 상품명 (정확 일치, 콤마 구분). 기본은 본체만
TARGET_PRODUCTS=닌텐도 스위치 2
